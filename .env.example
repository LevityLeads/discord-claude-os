# Discord Bot (create at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
ALLOWED_USER_IDS=

# Claude Code (run: claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=

# Supabase (for memory system)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (for embedding generation in memory system)
OPENAI_API_KEY=

# Base directory for team projects
BASE_PROJECT_DIR=/app/teams

# Rate limit per user per minute
RATE_LIMIT_PER_MINUTE=10

# Show estimated API cost in task results (false for Max plan)
SHOW_COST=false
